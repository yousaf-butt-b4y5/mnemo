# Copy to .env and fill what you need. All optional — sensible defaults apply.

# Local AI organizer (default: gemma3 on local Ollama)
MNEMO_OLLAMA_URL=http://localhost:11434
MNEMO_OLLAMA_MODEL=gemma3:4b

# Cloud fallback (personal vault only — never used for the work vault).
# Get a free key at openrouter.ai. Leave blank to stay 100% local.
OPENROUTER_API_KEY=
MNEMO_OPENROUTER_MODEL=google/gemini-2.5-flash-lite

# Server
MNEMO_HOST=127.0.0.1
MNEMO_PORT=7575

# Move large stores to D: when notes grow (app + small DB stays on F:)
# MNEMO_DATA_DIR=F:\Apps\Mnemo\data
# MNEMO_STORE_DIR=D:\Mnemo\store

# Token Odysseus must present to /mnemo/search (blank = open on localhost)
MNEMO_SHARED_TOKEN=
